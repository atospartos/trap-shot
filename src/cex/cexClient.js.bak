// src/cex/mexcClient.js
const axios = require('axios');
const crypto = require('crypto');
const logger = require('../core/logger');

class MexcClient {
    constructor() {
        this.baseURL = 'https://api.mexc.com';
        this.apiKey = process.env.MEXC_API_KEY;
        this.apiSecret = process.env.MEXC_API_SECRET;
        this.testMode = process.env.TEST_MODE === 'true';
        
        logger.info(`🔌 MEXC клиент инициализирован ${this.testMode ? '(ТЕСТОВЫЙ РЕЖИМ - order/test)' : '(РЕАЛЬНЫЙ РЕЖИМ)'}`);
    }

    // Для тестирования: использует /order/test
    // Для реальной торговли: использует /order
    async placeOrder(symbol, side, type, quantity, price = null) {
        const timestamp = Date.now();
        const params = {
            symbol: `${symbol}USDT`,
            side: side,
            type: type,
            quantity: quantity.toString(),
            timestamp: timestamp
        };

        if (price && type === 'LIMIT') {
            params.price = price.toString();
            params.timeInForce = 'GTC';
        }

        const endpoint = this.testMode ? '/api/v3/order/test' : '/api/v3/order';
        const signature = this.generateSignature(params);
        params.signature = signature;

        try {
            const response = await axios.post(`${this.baseURL}${endpoint}`, null, {
                params: params,
                headers: { 'X-MEXC-APIKEY': this.apiKey }
            });
            
            if (this.testMode) {
                logger.info(`🧪 [TEST] Ордер валиден: ${side} ${quantity} ${symbol} ${price ? `по ${price}` : 'рынок'}`);
            }
            
            return response.data;
        } catch (error) {
            const errorMsg = error.response?.data?.msg || error.message;
            logger.error(`❌ Ошибка ордера: ${errorMsg}`);
            
            if (this.testMode && error.response?.status === 400) {
                logger.error(`🧪 [TEST] Ошибка валидации: ${errorMsg}`);
            }
            
            return null;
        }
    }

    async cancelOrder(symbol, orderId) {
        const timestamp = Date.now();
        const params = {
            symbol: `${symbol}USDT`,
            orderId: orderId,
            timestamp: timestamp
        };

        const signature = this.generateSignature(params);
        params.signature = signature;

        try {
            const response = await axios.delete(`${this.baseURL}/api/v3/order`, {
                params: params,
                headers: { 'X-MEXC-APIKEY': this.apiKey }
            });
            return response.data;
        } catch (error) {
            logger.error(`Ошибка отмены ордера: ${error.response?.data?.msg || error.message}`);
            return null;
        }
    }

    async getOrder(symbol, orderId) {
        const timestamp = Date.now();
        const params = {
            symbol: `${symbol}USDT`,
            orderId: orderId,
            timestamp: timestamp
        };

        const signature = this.generateSignature(params);
        params.signature = signature;

        try {
            const response = await axios.get(`${this.baseURL}/api/v3/order`, {
                params: params,
                headers: { 'X-MEXC-APIKEY': this.apiKey }
            });
            return response.data;
        } catch (error) {
            logger.error(`Ошибка получения ордера: ${error.response?.data?.msg || error.message}`);
            return null;
        }
    }

async getTickerPrice(symbol) {
    try {
        // 🔥 ИСПРАВЛЕНИЕ: Делаем обычный GET-запрос БЕЗ подписи и API-ключа
        const response = await axios.get(`${this.baseURL}/api/v3/ticker/price`, {
            params: { symbol: `${symbol}USDT` },
            timeout: 5000
        });
        
        if (response.data && response.data.price) {
            return {
                symbol,
                price: parseFloat(response.data.price),
                volume: response.data.volume,
                timestamp: Date.now()
            };
        }
        return null;
    } catch (error) {
        logger.error(`Ошибка получения цены ${symbol}: ${error.message}`);
        return null;
    }
}

    generateSignature(params) {
        const queryString = Object.keys(params)
            .sort()
            .map(key => `${key}=${params[key]}`)
            .join('&');
        
        return crypto.createHmac('sha256', this.apiSecret)
            .update(queryString)
            .digest('hex');
    }
}

module.exports = new MexcClient();