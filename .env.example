# ------------------------------
# ОБЩИЕ НАСТРОЙКИ
# ------------------------------
NODE_ENV=development
CHECK_INTERVAL_MINUTES=0.1
# ========== ЛОГИРОВАНИЕ ==========
LOG_LEVEL=DEBUG  # Можно менять: DEBUG, INFO, WARN, ERROR, SIGNAL
# ------------------------------


# TELEGRAM
# ------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ------------------------------
# MEXC
# ------------------------------
MEXC_ENABLE=true
MEXC_API_KEY=
MEXC_SECRET_KEY=

# ------------------------------
# GATE.IO
# ------------------------------
GATEIO_ENABLE=true
GATEIO_API_KEY=
GATEIO_SECRET_KEY=

# ------------------------------
# ПАРАМЕТРЫ СТРАТЕГИИ
# ------------------------------
MIN_PRICE_DIFF_PERCENT=2
MIN_LIQUIDITY_USD=50000
MIN_VOLUME_24H_USD=10000

# ========== КОМИССИИ ==========
MEXC_MAKER_FEE=0.002
MEXC_TAKER_FEE=0.002
GATEIO_MAKER_FEE=0.002
GATEIO_TAKER_FEE=0.002

# ========== ТОРГОВЛЯ ==========
DEFAULT_POSITION_SIZE_USD=100
DEFAULT_HOLD_HOURS=1

# ========== КИТЫ ==========
WHALE_THRESHOLD_SOLANA=100000
WHALE_THRESHOLD_ETHEREUM=500000
WHALE_THRESHOLD_BSC=200000
WHALE_ANALYSIS_WINDOW_MINUTES=30